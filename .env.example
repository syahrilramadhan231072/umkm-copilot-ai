# ==========================================================
# Application
# ==========================================================

APP_NAME=UMKM Copilot AI
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=False
LOG_LEVEL=INFO

# ==========================================================
# Gemini
# ==========================================================

GEMINI_API_KEY= 
GEMINI_MODEL=gemini-2.5-flash

# ==========================================================
# Supabase
# ==========================================================

SUPABASE_URL=
SUPABASE_KEY=

# ==========================================================
# Streamlit
# ==========================================================

STREAMLIT_SERVER_PORT=8501

# ==========================================================
# Localization
# ==========================================================

DEFAULT_LANGUAGE=id
TIMEZONE=Asia/Jakarta
CURRENCY=IDR

# ==========================================================
# Feature Flags
# ==========================================================

ENABLE_MARKETING=True
ENABLE_INSIGHT=True
ENABLE_EXPORT=False
ENABLE_ANALYTICS=True
ENABLE_AI_ASSISTANT=True
